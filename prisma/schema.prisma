generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  company      String?
  role         UserRole      @default(FOUNDER)
  plan         Plan          @default(FREE)
  passwordHash String
  createdAt    DateTime      @default(now())
  applications Application[]
  documents    Document[]
}

enum UserRole {
  FOUNDER
  TTO_ADMIN
  ADMIN
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

model Application {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  grantType     GrantType
  status        AppStatus   @default(DRAFT)
  title         String
  companyName   String
  projectTitle  String
  techSummary   String      @db.Text
  sector        String?
  teamSize      Int?
  projectMonths Int?
  personnel     Json?
  materials     Json?
  subcontracts  Json?
  financials    Json?
  narrative     String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  documents     Document[]
}

enum GrantType {
  ZIM_INDIVIDUAL
  ZIM_COOPERATION
  EXIST_STARTUP
  EXIST_TRANSFER
}

enum AppStatus {
  DRAFT
  GENERATING
  REVIEW
  FINALIZED
  SUBMITTED
}

model Document {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  type          DocType
  fileName      String
  fileUrl       String
  version       Int         @default(1)
  createdAt     DateTime    @default(now())
}

enum DocType {
  NARRATIVE_PDF
  FINANCIAL_PDF
  FULL_APPLICATION_DOCX
  EASY_ONLINE_XML
}
